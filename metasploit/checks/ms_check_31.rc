# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# Microsoft Exchange ProxyShell RCE
use exploit/windows/http/exchange_proxyshell_rce
check
back
sleep 1

# Microsoft Exchange ProxyLogon RCE
use exploit/windows/http/exchange_proxylogon_rce
check
back
sleep 1

# Grafana Plugin JS Injection
use exploit/multi/http/grafana_plugin_js_injection
check
back
sleep 1

# WordPress RevSlider Upload & Execute
use exploit/multi/http/wp_revslider_upload_execute
check
back
sleep 1

# WordPress Admin AJAX Upload
use exploit/multi/http/wp_admin_ajax_upload
check
back
sleep 1

# ---- End ----
exit
