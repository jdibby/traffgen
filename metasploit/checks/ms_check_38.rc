# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# Apache Struts2 REST XStream Deserialization
use exploit/multi/http/struts2_rest_xstream
check
back
sleep 1

# Apache Struts2 Content-Type OGNL Injection (S2-045)
use exploit/multi/http/struts2_content_type_ognl
check
back
sleep 1

# Atlassian Confluence Widget Connector OGNL Injection
use exploit/multi/http/atlassian_confluence_widget_connector
check
back
sleep 1

# Oracle WebLogic Server Deserialization RCE (T3)
use exploit/multi/misc/weblogic_deserialize
check
back
sleep 1

# Jenkins CLI Java Deserialization
use exploit/multi/http/jenkins_cli_serialize
check
back
sleep 1

# ---- End ----
exit
