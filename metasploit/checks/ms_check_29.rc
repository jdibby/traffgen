# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# Magento Shoplift SQL Injection → RCE
use exploit/multi/http/magento_shoplift
check
back
sleep 1

# PrestaShop exec() Remote Code Execution
use exploit/multi/http/prestashop_exec
check
back
sleep 1

# Webmin Package Update RCE
use exploit/linux/http/webmin_packageup_rce
check
back
sleep 1

# Cacti Monitoring Remote Code Execution
use exploit/multi/http/cacti_monitoring_rce
check
back
sleep 1

# Pulse Secure VPN Account Enumeration
use auxiliary/scanner/http/pulse_secure_vpn_enum
run
back
sleep 1

# ---- End ----
exit
