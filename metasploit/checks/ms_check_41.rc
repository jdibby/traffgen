# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# Atlassian Confluence Namespace OGNL Injection
use exploit/multi/http/confluence_namespace_ognl
check
back
sleep 1

# Atlassian Confluence Widget Connector Injection
use exploit/multi/http/confluence_widget_connector
check
back
sleep 1

# Atlassian Crowd Java Deserialization RCE
use exploit/multi/http/atlassian_crowd_deserial_rce
check
back
sleep 1

# Atlassian Bitbucket Git Command Injection
use exploit/multi/http/atlassian_bitbucket_git_command_injection
check
back
sleep 1

# F5 BIG-IP iControl REST Auth Bypass to RCE
use exploit/linux/http/f5_icontrol_rest_auth_bypass_rce
check
back
sleep 1

# ---- End ----
exit
