# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# HTTP Form Field Fuzzer
use auxiliary/fuzzers/http/http_form_field
run
back
sleep 1

# SMB Version Scanner
use auxiliary/scanner/smb/smb_version
run
back
sleep 1

# SSH Version Scanner
use auxiliary/scanner/ssh/ssh_version
run
back
sleep 1

# ---- End ----
exit
