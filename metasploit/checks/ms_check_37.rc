# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# MikroTik Winbox User Enumeration
use exploit/linux/http/mikrotik_winbox_user_enum
check
back
sleep 1

# MikroTik REST Exec
use exploit/linux/http/mikrotik_rest_exec
check
back
sleep 1

# Jenkins CLI Java Deserialization RCE
use exploit/multi/http/jenkins_cli_serialize_rce
check
back
sleep 1

# Jenkins Groovy Script RCE
use exploit/multi/http/jenkins_groovy_script_rce
check
back
sleep 1

# Apache Struts2 Development Mode RCE
use exploit/multi/http/struts2_dev_mode_rce
check
back
sleep 1

# ---- End ----
exit
