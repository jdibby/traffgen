# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# Nagios XI Chained RCE
use exploit/linux/http/nagios_xi_chained_rce
check
back
sleep 1

# OpenNMS Graph RCE
use exploit/linux/http/opennms_graph_rce
check
back
sleep 1

# GLPI Install RCE
use exploit/multi/http/glpi_install_rce
check
back
sleep 1

# Atlassian Bamboo Agent RCE
use exploit/multi/http/atlassian_bamboo_agent_rce
check
back
sleep 1

# Atlassian Crowd SSO RCE
use exploit/multi/http/atlassian_crowd_sso_rce
check
back
sleep 1

# ---- End ----
exit
