# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# SPIP BigUp Plugin Unauthenticated RCE
use exploit/multi/http/spip_bigup_unauth_rce
check
back
sleep 1

# Atlassian Confluence Namespace OGNL Injection
use exploit/multi/http/atlassian_confluence_namespace_ognl_injection
check
back
sleep 1

# Softing Secure Integration Server RCE
use exploit/windows/http/softing_sis_rce
check
back
sleep 1

# Cacti Pollers SQLi to RCE
use exploit/multi/http/cacti_pollers_sqli_rce
check
back
sleep 1

# Microsoft Exchange ChainedSerializationBinder RCE
use exploit/windows/http/exchange_chainedserializationbinder_rce
check
back
sleep 1

# ---- End ----
exit
