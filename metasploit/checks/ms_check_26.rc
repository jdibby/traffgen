# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# Drupal Drupalgeddon3 RCE
use exploit/multi/http/drupal_drupalgeddon3
check
back
sleep 1

# Joomla HTTP Header RCE
use exploit/multi/http/joomla_http_header_rce
check
back
sleep 1

# Zimbra XXE
use exploit/linux/http/zimbra_xxe
check
back
sleep 1

# Zimbra Auth Bypass
use exploit/linux/http/zimbra_auth_bypass
check
back
sleep 1

# Tomcat Manager Upload RCE
use exploit/multi/http/tomcat_mgr_upload
check
back
sleep 1

# ---- End ----
exit
