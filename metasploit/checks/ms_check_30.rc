# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# Ivanti Connect Secure Command Injection
use exploit/linux/http/ivanti_connect_secure_cmd_injection
check
back
sleep 1

# F5 BIG-IP TMUI Remote Code Execution
use exploit/linux/http/f5_bigip_tmui_rce
check
back
sleep 1

# Cisco Smart Install Scanner
use auxiliary/scanner/http/cisco_smart_install
run
back
sleep 1

# Palo Alto PAN-OS Admin Management Finder
use auxiliary/scanner/http/panos_admin_mgmt_finder
run
back
sleep 1

# Microsoft SharePoint Remote Code Execution
use exploit/windows/http/sharepoint_rce
check
back
sleep 1

# ---- End ----
exit
