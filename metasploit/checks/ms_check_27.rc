# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# JBoss Vulnerable Deployment
use exploit/multi/http/jboss_vuln_deploy
check
back
sleep 1

# Apache OFBiz Deserialization RCE
use exploit/multi/http/apache_ofbiz_deserialization
check
back
sleep 1

# Apache Solr Velocity RCE
use exploit/multi/http/apache_solr_velocity_rce
check
back
sleep 1

# Elastic Head RCE
use exploit/multi/http/elastic_head_rce
check
back
sleep 1

# Kibana Timelion Command Injection
use exploit/linux/http/kibana_timelion_cmd_injection
check
back
sleep 1

# ---- End ----
exit
