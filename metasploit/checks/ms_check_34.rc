# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# Jenkins Metaprogramming RCE
use exploit/multi/http/jenkins_metaprogramming_rce
check
back
sleep 1

# Glassfish Deploy
use exploit/multi/http/glassfish_deploy
check
back
sleep 1

# IBM WebSphere Java Deserialize
use exploit/multi/http/ibm_websphere_java_deserialize
check
back
sleep 1

# ColdFusion FCKeditor RCE
use exploit/multi/http/coldfusion_fckeditor_rce
check
back
sleep 1

# Bitbucket Git Command RCE
use exploit/multi/http/bitbucket_git_command_rce
check
back
sleep 1

# ---- End ----
exit
