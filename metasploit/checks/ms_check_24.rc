# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# F5 iControl REST Auth Bypass RCE
use exploit/linux/http/f5_icontrol_rest_auth_bypass_rce
check
back
sleep 1

# Fortinet FortiOS SSL VPN Information Disclosure
use auxiliary/gather/fortinet_fortios_ssl_vpn_info_disclosure
check
back
sleep 1

# Citrix Directory Traversal Scanner
use auxiliary/scanner/http/citrix_dir_traversal
check
back
sleep 1

# Apache Struts2 Namespace OGNL Injection
use exploit/multi/http/struts2_namespace_ognl
check
back
sleep 1

# Apache Struts2 Content-Type OGNL Injection
use exploit/multi/http/struts2_content_type_ognl
check
back
sleep 1

# ---- End ----
exit
