# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# Monitorr unauthenticated RCE (CVE-2020-28871)
use exploit/multi/http/monitorr_webshell_rce_cve_2020_28871
check
back
sleep 1

# NorthStar C2 XSS → Agent RCE
use exploit/windows/http/northstar_c2_xss_to_agent_rce
check
back
sleep 1

# Rockwell FactoryTalk View SE SCADA Unauth RCE
use exploit/windows/scada/rockwell_factorytalk_rce
check
back
sleep 1

# Microsoft SharePoint Unsafe Control & ViewState RCE
use exploit/windows/http/sharepoint_unsafe_control
# set DOMAIN domain.local
# set USERNAME user
# set PASSWORD pass
check
back
sleep 1

# ---- End ----
exit
