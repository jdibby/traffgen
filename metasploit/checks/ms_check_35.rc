# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# Bitbucket Authenticated RCE
use exploit/multi/http/bitbucket_authenticated_rce
check
back
sleep 1

# GitLab Shell RCE
use exploit/multi/http/gitlab_shell_rce
check
back
sleep 1

# GitLab CI LFS RCE
use exploit/multi/http/gitlab_ci_lfs_rce
check
back
sleep 1

# Roundcube Deserialization
use exploit/multi/http/roundcube_deserialization
check
back
sleep 1

# Horde Webmail RCE
use exploit/multi/http/horde_webmail_rce
check
back
sleep 1

# ---- End ----
exit
