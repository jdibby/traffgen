# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# SOGo Sieve Command Execution
use exploit/multi/http/sogo_sieve_cmd_exec
check
back
sleep 1

# WebLogic Deserialization
use exploit/multi/misc/weblogic_deserialize
check
back
sleep 1

# WebLogic T3 Exec
use exploit/multi/misc/weblogic_t3_exec
check
back
sleep 1

# D-Link DIR RCE
use exploit/linux/http/dlink_dir_rce
check
back
sleep 1

# Netgear ReadyShare RCE
use exploit/linux/http/netgear_readyshare_rce
check
back
sleep 1

# ---- End ----
exit
