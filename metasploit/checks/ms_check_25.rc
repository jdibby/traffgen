# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# Spring Cloud Function SpEL Injection
use exploit/multi/http/spring_cloud_function_spel_injection
check
back
sleep 1

# Spring Core RCE (Spring4Shell)
use exploit/multi/http/spring_core_rce
check
back
sleep 1

# Jenkins Script Console RCE
use exploit/multi/http/jenkins_script_console
check
back
sleep 1

# Jenkins CLI Deserialization RCE
use exploit/multi/http/jenkins_cli_deserialize
check
back
sleep 1

# Drupal Drupalgeddon2 RCE
use exploit/multi/http/drupal_drupalgeddon2
check
back
sleep 1

# ---- End ----
exit
