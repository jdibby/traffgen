# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# PRTG Network Monitor – Authenticated RCE (CVE-2023-32781)
use exploit/windows/http/prtg_authenticated_rce_cve_2023_32781
set USERNAME fake_user
set PASSWORD fake_password
check
back
sleep 1

# WordPress Royal Elementor Addons RCE
use exploit/multi/http/wp_royal_elementor_addons_rce
check
back
sleep 1

# mySCADA myPRO Manager – Unauthenticated Command Injection (CVE-2024-47407)
use exploit/windows/scada/mypro_mgr_cmd
check
back
sleep 1

# Zoho Password Manager Pro – XML-RPC Java Deserialization RCE
use exploit/windows/http/zoho_password_manager_pro_xml_rpc_rce
check
back
sleep 1

# ---- End ----
exit
