# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# SugarCRM REST PHP Unserialize
use exploit/multi/http/sugarcrm_rest_unserialize
check
back
sleep 1

# SuiteCRM Log File Remote Code Execution
use exploit/multi/http/suitecrm_log_file_rce
check
back
sleep 1

# Apache Druid Remote Code Execution
use exploit/multi/http/apache_druid_rce
check
back
sleep 1

# Apache Superset Session RCE
use exploit/multi/http/apache_superset_session_rce
check
back
sleep 1

# Oracle Access Manager Unauthenticated RCE (CVE-2021-35587)
use exploit/multi/http/oracle_access_manager_rce_cve_2021_35587
check
back
sleep 1

# ---- End ----
exit
