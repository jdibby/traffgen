# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# Log4Shell HTTP Header Injection (CVE-2021-44228 variant)
use exploit/multi/http/log4shell_header_injection
check
back
sleep 1

# ManageEngine ADSelfService Plus Unauthenticated SAML RCE (CVE-2022-47966)
use exploit/multi/http/manageengine_adselfservice_plus_saml_rce_cve_2022_47966
check
back
sleep 1

# ManageEngine ServiceDesk Plus Unauthenticated SAML RCE (CVE-2022-47966)
use exploit/multi/http/manageengine_servicedesk_plus_saml_rce_cve_2022_47966
check
back
sleep 1

# ManageEngine OpManager SumPDU Java Deserialization
use exploit/multi/http/opmanager_sumpdu_deserialization
check
back
sleep 1

# SonicWall SSL-VPN Shell Injection (CVE-2023-34124)
use exploit/multi/http/sonicwall_shell_injection_cve_2023_34124
check
back
sleep 1

# ---- End ----
exit
