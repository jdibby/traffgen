# Automated vulnerability verification script.
# WARNING: Use only in a legal, controlled lab environment.

resource /opt/metasploit-framework/ms_checks/checks/_common.rc

# ---- Module Checks ----

# SAP WebDynpro Deserialization
use exploit/multi/http/sap_webdynpro_deserialization
check
back
sleep 1

# Oracle Report Server Deserialization
use exploit/multi/http/oracle_report_server_deserialization
check
back
sleep 1

# SaltStack Salt API Command Exec
use exploit/multi/http/saltstack_salt_api_cmd_exec
check
back
sleep 1

# Roxy-WI RCE
use exploit/multi/http/roxywi_rce
check
back
sleep 1

# Nexus Repository RCE
use exploit/multi/http/nexus_repository_rce
check
back
sleep 1

# ---- End ----
exit
